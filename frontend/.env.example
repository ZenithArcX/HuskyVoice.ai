# VITE_API_URL — The base URL of your FastAPI backend
#
# In development: FastAPI runs on port 8000 locally
# In production:  Replace with your Render.com deployment URL
#
# NOTE: In Vite, env variables MUST start with VITE_ to be accessible
#       in the browser via import.meta.env.VITE_*
#       Variables without VITE_ prefix are hidden from the browser.

VITE_API_URL=http://localhost:8000
