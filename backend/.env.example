# ============================================================
# .env.example — Copy this to .env and fill in real values
# NEVER commit your actual .env file to Git!
# ============================================================

# MongoDB Atlas connection string
# Get this from: Atlas Dashboard → Connect → Drivers → Copy connection string
# Replace <password> with your actual Atlas database user password
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Name of the MongoDB database to use
DB_NAME=leavedb

# Secret key used to sign and verify JWT tokens
# Generate a strong one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_a_long_random_secret_string_here

# How long (in minutes) until a JWT token expires
# 60 = 1 hour. Adjust for your security requirements.
JWT_EXPIRE_MINUTES=60

# Comma-separated list of allowed frontend origins for CORS
# Local dev: http://localhost:5173
# Production: add your Vercel URL too
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
